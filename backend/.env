#node environment
NODE_ENV=development

#server
PORT=8080
HOST=0.0.0.0

#postgresSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=social_media
POSTGRES_URL=postgresql://admin:password123@localhost:5432/social_media

#mongodb
MONGO_USER=admin
MONGO_PASSWORD=password123
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=social_messages
MONGO_URL=mongodb://admin:password123@localhost:27017/social_messages?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password123
REDIS_URL=redis://:password123@localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_2024
JWT_EXPIRE=7d

# App Settings
CORS_ORIGIN=http://localhost:3000
MAX_UPLOAD_SIZE=10mb